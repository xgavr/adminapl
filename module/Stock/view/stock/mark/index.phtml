<script type="text/javascript">
    var $table = $('#table'),
        $ok = $('#ok'),
        curentRowIndex = -1;
    
    function setCurrentIndex(index){
        curentRowIndex = index;
    }
    
    function getCurrentIndex(){
        return curentRowIndex;
    }    
    
    function refreshTable(){
        $('#table').bootstrapTable('refresh');
    }
    
    function changeStatus(rowId, newStatus){
        var dialog = bootbox.dialog({
            message: '<p class="text-center"><i class="fa fa-spin fa-spinner"></i>Подождите, пока мы что-нибудь сделаем ...</p>',
            closeButton: true
        });        
        $.get( "/mark/status/"+rowId+'?status='+newStatus, function(data){
            $table.bootstrapTable('updateByUniqueId', {id: rowId, row: data});
            dialog.modal('hide');
        });        
    }    
    
    function checkMarkStatus(row){
        var dialog = bootbox.dialog({
            message: '<p class="text-center"><i class="fa fa-spin fa-spinner"></i>Подождите, пока мы что-нибудь сделаем ...</p>',
            closeButton: true
        });        
        $.get( "/mark/mark-status/"+row.id, function(data){
            $table.bootstrapTable('updateByUniqueId', {id: row.id, row: data});
            dialog.modal('hide');
        });        
    }    
    
    $(function () {
        $table.on('load-success.bs.table', function (e, res) {
            tableRowClick();  
        });        
        
        $(".inputclear").click(function(){
            $("#searchinput").val('');
            refreshTable();
        });
        
        $(".mark-statuses").click(function(){
            var dialog = bootbox.dialog({
                message: '<p class="text-center"><i class="fa fa-spin fa-spinner"></i>Подождите, пока мы что-нибудь сделаем ...</p>',
                closeButton: true
            });            
            $.get( "/mark/mark-statuses/", function(data){
                refreshTable();
                dialog.modal('hide');
            }); 
        });
        
        $(document).on('change', '.refresh-table', function (e) {
            refreshTable();
        });  
                        
    });    
    
    function queryParams(params) {
        $('#toolbar').find('input[name]').each(function () {
            params[$(this).attr('name')] = $(this).val();
        });
        $('#toolbar').find('select[name]').each(function () {
            params[$(this).attr('name')] = $(this).val();
        });
        limit = $('.page-size').html();
        if (limit){
            params.limit = limit;
        }    
        offset = $('li.page-number.active a').html();
        if (offset){
            params.offset = params.limit * (offset - 1);
        }

        
        return params;
    }
    
    function rowStyle(row, index) {
        var retired = 'tablerow';
        if (row.markStatus === <?= Mark::MARK_RETIRED?>){
            retired += ' success';
        }    
        if (row.markStatus === <?= Mark::MARK_NOT_FOUND?>){
            retired += ' error';
        }    
        if (row.markStatus === <?= Mark::MARK_NOT_LISTED?>){
            retired += ' warning';
        }    
        if (row.status === <?= Mark::STATUS_RETIRED?>){
            retired += ' retired';
        }    
        if (row.order.status !== <?= Order::STATUS_SHIPPED?>){
            retired += ' retired-muted';
        }    
        return {classes: retired};    
    }    
    
    function dateFormatter(value, row){
        var date = new Date(value);
        return $.format.date(date, "dd.MM.yyyy");
    }     
    
    function markLinkFormatter(value, row){
        return [
            '<nobr>',
            '<a href="/goods/view/' + row.good.id + '" class="btn btn-link btn-xs" title="Перейти на страницу товара" target="_blank">',
            '<span class="glyphicon glyphicon-link"></span></a>'+row.good.code,
            '</nobr>'
        ].join(''); 
    }    
    
    function orderFormatter(value, row){
        return [
            '<nobr>',
            "<a href='#' class='order-view-show' modal-url='/order/view/"+row.order.id+"'>" + row.order.aplId+"</a>",
            '</nobr>'
        ].join(''); 
    }    
    
    function markFormatter(value, row){
        return [
            '<nobr>',
            value.slice(0, 31),
            '</nobr>'
        ].join(''); 
    }    
    
      var menu = new BootstrapMenu('.tablerow', {
        fetchElementData: function(rowElem) {
            setCurrentIndex($(rowElem).attr('data-index'));
            return $table.bootstrapTable('getData')[getCurrentIndex()];
        },
        actionsGroups: [
           ['markStatus'], ['statusActiv', 'statusRetired']
        ],      
        actions: {
            markStatus: {
                name: 'Проверить состояние кода',
                iconClass: 'glyphicon glyphicon-ok',
                onClick: function(row) {
                    checkMarkStatus(row);
                },
                isEnabled: function(row) {
                    return true;
                }                
            }, 
            statusActiv: {
                name: 'Сделать активным',
                iconClass: 'glyphicon glyphicon-ok-circle',
                onClick: function(row) {
                    changeStatus(row.id, <?= Mark::STATUS_ACTIVE?>);
                },
                isShown: function(row) {
                    return row.status === <?= Mark::STATUS_RETIRED?>;
                },
                isEnabled: function(row) {
                    return row.status === <?= Mark::STATUS_RETIRED?>;
                }                
            }, 
            statusRetired: {
                name: 'Сделать не активным',
                iconClass: 'glyphicon glyphicon-ban-circle',
//                classNames: 'bg-danger',
                onClick: function(row) {
                    changeStatus(row.id, <?= Mark::STATUS_RETIRED?>);
                },
                isShown: function(row) {
                    return row.status === <?= Mark::STATUS_ACTIVE?>;
                },
                isEnabled: function(row) {
                    return row.status === <?= Mark::STATUS_ACTIVE?>;
                }                
            }
        }
    });    
    
    
    function responseHandler(res) {
        return res;
    }    
</script>
